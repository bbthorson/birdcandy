---
import '../styles/global.css';
import Sidebar from '../components/layout/Sidebar.astro';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = 'Bird Candy — Strategy for the open protocol transition',
  description = 'Bird Candy is a strategy studio helping companies navigate the shift from proprietary platforms to open protocols.',
  currentPath = '/',
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="lg:grid lg:grid-cols-[240px_1fr] min-h-screen max-w-[1400px] mx-auto">
      <Sidebar currentPath={currentPath} />
      <main class="px-6 py-10 pb-30 lg:px-16 lg:py-10">
        <slot />
      </main>
    </div>
  </body>
</html>
