---
const sections = [
  { href: '#the-shift', label: 'The Shift' },
  { href: '#capabilities', label: 'What We Do' },
  { href: '#why-studio', label: 'Why a Studio' },
  { href: '#contact', label: 'Contact' },
];
---

<aside class="sidebar hidden lg:flex sticky top-0 h-screen flex-col justify-between border-r border-rule px-8 py-10">
  <div>
    <a href="/" class="mb-12 flex items-center gap-2.5 no-underline">
      <div class="flex h-7 w-7 items-center justify-center rounded-md bg-fg">
        <svg class="h-5 w-5 text-bg" viewBox="0 0 128 128" xmlns="http://www.w3.org/2000/svg">
          <path fill="currentColor" d="M64 20 24 56 104 56Z"/>
          <rect fill="currentColor" x="38" y="53" width="52" height="53" rx="4"/>
          <circle cx="64" cy="73" r="12" fill="#ff3d8b"/>
          <rect x="55" y="88" width="18" height="5" rx="2.5" fill="#2b5cff"/>
        </svg>
      </div>
      <span class="text-[15px] font-medium tracking-tight">Bird Candy</span>
    </a>

    <nav>
      <ul class="flex flex-col gap-1.5 list-none p-0">
        {sections.map((item) => (
          <li>
            <a
              href={item.href}
              class="sidebar-link block py-1 text-sm text-fg-tertiary no-underline transition-colors duration-150 hover:text-accent"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <div>
    <a
      href="https://bsky.app/profile/birdcandy.com"
      class="font-mono text-xs text-fg-tertiary no-underline transition-colors duration-150 hover:text-accent"
      target="_blank"
      rel="noopener"
    >
      @birdcandy.com
    </a>
  </div>
</aside>
